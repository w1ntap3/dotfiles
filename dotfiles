#!/bin/bash

REPO="$HOME/Documents/dotfiles"
MANIFEST="$REPO/dotfile_list.txt"

sync_all() {
    if [[ ! -f "$MANIFEST" ]]; then
        echo "Error: $MANIFEST not found."
        exit 1
    fi

    while IFS=' ' read -r src dest; do
        [[ -z "$src" ]] && continue

        expanded="${src/#\~/$HOME}"

        if [[ ! -e "$expanded" ]]; then
            echo "Warning: $src does not exist, skipping."
            continue
        fi

        dest_path="$REPO/$dest"

        if [[ -d "$expanded" ]]; then
            mkdir -p "$dest_path"
            cp -r "$expanded/." "$dest_path/"
            echo "Synced [dir]:  $src -> $dest/"
        else
            mkdir -p "$(dirname "$dest_path")"
            cp "$expanded" "$dest_path"
            echo "Synced [file]: $src -> $dest"
        fi
    done < "$MANIFEST"
}

case "$1" in
    "")
        echo "Syncing dotfiles..."
        sync_all
        echo "Done."
        ;;
    git)
        if [[ -z "$2" ]]; then
            echo "Usage: dotfiles git <commit message>"
            exit 1
        fi
        echo "Syncing dotfiles..."
        sync_all
        cd "$REPO" || exit 1
        git add -A
        if git diff --staged --quiet; then
            echo "Nothing new to commit."
        else
            git commit -m "$2"
            git push
        fi
        ;;
    add)
        if [[ -z "$2" ]]; then
            echo "Usage: dotfiles add <source> [folder]"
            exit 1
        fi

        src_input="$2"
        expanded="${src_input/#\~/$HOME}"

        if [[ ! -e "$expanded" ]]; then
            echo "Error: $src_input does not exist."
            exit 1
        fi

        dest="${3:-$(basename "$expanded")}"

        touch "$MANIFEST"
        if grep -q "^$src_input " "$MANIFEST"; then
            echo "Already tracked: $src_input"
            exit 0
        fi

        echo "$src_input $dest" >> "$MANIFEST"
        echo "Registered: $src_input -> $dest"
        ;;
    *)
        echo "Usage:"
        echo "  dotfiles                     sync all tracked files to repo"
        echo "  dotfiles git <message>       sync and push to remote"
        echo "  dotfiles add <src> [folder]  register file or directory"
        ;;
esac
